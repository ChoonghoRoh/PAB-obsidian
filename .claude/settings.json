{
  "autoCompact": "disabled",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(python3:*)",
      "Bash(docker-compose ps:*)",
      "Bash(docker-compose logs:*)",
      "Bash(docker compose:*)",
      "Bash(curl:*)",
      "Bash(chmod:*)",
      "Bash(docker exec:*)",
      "Bash(node -c:*)",
      "Bash(git checkout:*)",
      "Bash(docker logs:*)",
      "Bash(./scripts/backup/backup.sh:*)",
      "Bash(ls:*)",
      "Bash(git log:*)",
      "Bash(wc:*)",
      "Bash(just:*)",
      "Skill(phase-init:*)",
      "Skill(ssot-reload:*)",
      "Skill(gate-check:*)",
      "Skill(refactor-scan:*)",
      "Skill(rules-lookup:*)"
    ]
  },
  "hooks": {
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-task-completed.sh",
            "timeout": 30,
            "statusMessage": "Task 완료 품질 검사 실행 중..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ssot-freshness-check.sh",
            "timeout": 10,
            "statusMessage": "SSOT 진입점 확인 중..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hr1-guard.sh",
            "timeout": 5,
            "statusMessage": "HR-1 코드 수정 규칙 확인 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/line-count-monitor.sh",
            "timeout": 10,
            "statusMessage": "HR-5 줄수 모니터링 중..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux"
}
