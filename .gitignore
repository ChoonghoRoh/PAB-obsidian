# Claude Code 로컬 설정 (개인 환경/잠재 비밀)
.claude/settings.local.json

# Obsidian per-machine 상태 (실제 vault = PAB-LLMDATA/)
# 추적 대상: app.json, core-plugins.json, appearance.json (프로젝트 공통 정책)
# 무시 대상: workspace*, cache, graph, community-plugins, plugins 등 per-machine 상태
# (plugins/ 통째 무시 — LiveSync 플러그인 자체는 각 기기가 LiveSync로 동기화)
PAB-LLMDATA/.obsidian/workspace*.json
PAB-LLMDATA/.obsidian/cache
PAB-LLMDATA/.obsidian/graph.json
PAB-LLMDATA/.obsidian/community-plugins.json
PAB-LLMDATA/.obsidian/plugins/
PAB-LLMDATA/.obsidian/themes/
PAB-LLMDATA/.obsidian/snippets/
PAB-LLMDATA/.obsidian/hotkeys.json

# Obsidian 휴지통 / 자동 백업
.trash/
PAB-LLMDATA/.obsidian/trash/

# 에디터/IDE
.vscode/
.idea/
*.swp
*.swo

# 비밀 환경변수
.env
.env.local
.env.production

# 외부 차용 자원 (다른 PAB 프로젝트에서 상속, 본 프로젝트는 reference만)
SSOT/
scripts/

# 로그/임시 파일
*.log
*.tmp
node_modules/

# 외부 오픈소스 클론 (분석용, 자체 .git 포함)
sub/
